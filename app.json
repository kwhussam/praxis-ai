{
  "expo": {
    "name": "PraxisShield AI",
    "slug": "praxisshield",
    "scheme": "praxisshield",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.praxisshield.app",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "PraxisShield prüft ausschließlich technische Metadaten im lokalen Praxisnetz, z. B. Routerdienste und UPnP. Es werden keine Patientendaten, Dateien oder Praxissoftware-Inhalte gelesen.",
        "NSLocationWhenInUseUsageDescription": "iOS benötigt diese Berechtigung, um den verbundenen WLAN-Namen für die lokale Sicherheitsbewertung zu lesen.",
        "NSBonjourServices": [
          "_http._tcp",
          "_https._tcp",
          "_ipp._tcp",
          "_printer._tcp",
          "_pdl-datastream._tcp",
          "_smb._tcp",
          "_afpovertcp._tcp",
          "_nfs._tcp",
          "_rtsp._tcp",
          "_workstation._tcp",
          "_scanner._tcp",
          "_dicom._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "ai.praxisshield.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A1628"
      },
      "permissions": [
        "ACCESS_WIFI_STATE",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "NEARBY_WIFI_DEVICES",
        "CHANGE_WIFI_MULTICAST_STATE",
        "CHANGE_WIFI_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "./plugins/with-ios-metro-localhost-fallback",
      "./plugins/with-network-security-probe",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
